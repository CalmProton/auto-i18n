# Auto-i18n v2 Environment Configuration
# Copy to .env and fill in values.
# All settings below can also be edited at runtime via the Settings tab in the dashboard.

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Optional. Set to enable API key authentication on all routes.
# ACCESS_KEY=your-secret-access-key

# ─── Translation (Real-time) ───────────────────────────────────────────────────
# OpenRouter is used for all real-time translation. Pick any model from
# https://openrouter.ai/models — e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Translation (Batch — 50% cost saving, async) ─────────────────────────────
# Configure ONE or BOTH. BATCH_PROVIDER=auto picks whichever has a key set.
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BATCH_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BATCH_MODEL=claude-3-haiku-20240307
# BATCH_PROVIDER=auto

# ─── Mock Mode ────────────────────────────────────────────────────────────────
# Set to true to skip real LLM calls (useful for testing CI integrations).
# MOCK_MODE=false

# ─── Git Forge ────────────────────────────────────────────────────────────────
# GIT_FORGE controls how translated files are delivered back to your repo.
# Options: github | gitlab | webhook | none
#
#   github  — creates a branch + commits + PR on GitHub
#   gitlab  — creates a branch + commits + MR on GitLab
#   webhook — POSTs translated files to WEBHOOK_URL (CI handles git itself)
#   none    — translations stored in DB; retrieve via GET /api/sessions/:id/output
GIT_FORGE=none

# GitHub forge
# GITHUB_TOKEN=your-github-token
# GITHUB_API_URL=https://api.github.com
# GIT_CREATE_ISSUES=false

# GitLab forge
# GITLAB_TOKEN=your-gitlab-token
# GITLAB_API_URL=https://gitlab.com

# Webhook forge
# WEBHOOK_URL=https://your-ci.example.com/translation-done
# WEBHOOK_SECRET=your-webhook-secret
